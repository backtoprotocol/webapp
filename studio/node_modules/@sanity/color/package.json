{
  "name": "@sanity/color",
  "version": "3.0.7",
  "description": "The Sanity color palette.",
  "keywords": [
    "color",
    "palette",
    "sanity"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/ui/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/ui.git",
    "directory": "packages/color"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@sanity/tsdown-config": "^0.19.6",
    "@types/node": "^24.13.3",
    "rimraf": "^5.0.5",
    "tsdown": "^0.22.12",
    "typescript": "6.0.3",
    "unrun": "^0.3.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "esm.sh": {
    "bundle": false
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "generate": "unrun scripts/generate.ts && pnpm --workspace-root exec oxfmt packages/color/src/color.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsdown --watch"
  }
}