{
  "name": "@sanity/types",
  "version": "6.6.0",
  "description": "Type definitions for common Sanity data structures",
  "keywords": [
    "cms",
    "content",
    "headless",
    "realtime",
    "sanity",
    "types",
    "typescript"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/sanity/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/sanity.git",
    "directory": "packages/@sanity/types"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@sanity/client": "^7.24.0",
    "@sanity/media-library-types": "^1.6.0"
  },
  "devDependencies": {
    "@sanity/pkg-utils": "^11.0.13",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "rimraf": "^6.1.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "@repo/test-config": "6.6.0",
    "@repo/tsconfig": "6.6.0",
    "@repo/package.config": "6.6.0"
  },
  "peerDependencies": {
    "@types/react": "*"
  },
  "browserslist": [
    "node >=22.12",
    "baseline 2024"
  ],
  "scripts": {
    "build": "pkg-utils build --strict --check --clean",
    "check:types": "(cd ../../.. && tsgo --project packages/@sanity/types/tsconfig.lib.json --erasableSyntaxOnly)",
    "clean": "rimraf lib",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "watch": "pkg-utils watch"
  }
}