{
  "name": "@sanity/cli-core",
  "version": "2.5.1",
  "description": "Sanity CLI core package",
  "keywords": [
    "cli",
    "cms",
    "content",
    "headless",
    "realtime",
    "sanity",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/cli.git",
    "directory": "packages/@sanity/cli-core"
  },
  "files": [
    "./dist",
    "!./dist/**/__tests__"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/_exports/index.js",
  "types": "./dist/_exports/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/_exports/index.ts",
      "default": "./dist/_exports/index.js"
    },
    "./apiClient": {
      "source": "./src/apiClient.ts",
      "default": "./dist/apiClient.js"
    },
    "./browser": {
      "source": "./src/_exports/browser.ts",
      "default": "./dist/_exports/browser.js"
    },
    "./config": {
      "source": "./src/_exports/config.ts",
      "default": "./dist/_exports/config.js"
    },
    "./debug": {
      "source": "./src/_exports/debug.ts",
      "default": "./dist/_exports/debug.js"
    },
    "./errors": {
      "source": "./src/_exports/errors.ts",
      "default": "./dist/_exports/errors.js"
    },
    "./package-manager": {
      "source": "./src/_exports/package-manager.ts",
      "default": "./dist/_exports/package-manager.js"
    },
    "./request": {
      "source": "./src/_exports/request.ts",
      "default": "./dist/_exports/request.js"
    },
    "./schemas": {
      "source": "./src/_exports/schemas.ts",
      "default": "./dist/_exports/schemas.js"
    },
    "./tasks": {
      "source": "./src/_exports/tasks.ts",
      "default": "./dist/_exports/tasks.js"
    },
    "./telemetry": {
      "source": "./src/_exports/telemetry.ts",
      "default": "./dist/_exports/telemetry.js"
    },
    "./types": {
      "source": "./src/_exports/types.ts",
      "default": "./dist/_exports/types.js"
    },
    "./undeploy": {
      "source": "./src/_exports/undeploy.ts",
      "default": "./dist/_exports/undeploy.js"
    },
    "./util": {
      "source": "./src/_exports/util.ts",
      "default": "./dist/_exports/util.js"
    },
    "./ux": {
      "source": "./src/_exports/ux.ts",
      "default": "./dist/_exports/ux.js"
    },
    "./SanityCommand": {
      "source": "./src/SanityCommand.ts",
      "default": "./dist/SanityCommand.js"
    },
    "./ExitCodes": {
      "source": "./src/exitCodes.ts",
      "default": "./dist/exitCodes.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@oclif/core": "^4.11.14",
    "@sanity/client": "^7.23.2",
    "boxen": "^8.0.1",
    "debug": "^4.4.3",
    "empathic": "^2.0.1",
    "get-it": "^8.8.0",
    "get-tsconfig": "^4.14.0",
    "import-meta-resolve": "^4.2.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "json-lexer": "^1.2.0",
    "log-symbols": "^7.0.1",
    "ora": "^9.0.0",
    "rxjs": "^7.8.2",
    "tsx": "^4.23.1",
    "vite": "^8.1.5",
    "vite-node": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@sanity/pkg-utils": "^11.0.9",
    "@sanity/telemetry": "^1.1.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/debug": "^4.1.13",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.20.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.7.0",
    "publint": "^0.3.21",
    "sanity": "^6.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "@repo/package.config": "0.0.1",
    "@repo/tsconfig": "3.70.0",
    "@sanity/eslint-config-cli": "1.1.3"
  },
  "peerDependencies": {
    "babel-plugin-react-compiler": "*"
  },
  "peerDependenciesMeta": {
    "babel-plugin-react-compiler": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "build": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src",
    "build:types": "pkg-utils build --emitDeclarationOnly",
    "check:types": "tsc --noEmit",
    "lint": "eslint .",
    "publint": "publint",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  }
}