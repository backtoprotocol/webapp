{
  "name": "@sanity/cli-build",
  "version": "5.0.0",
  "description": "Internal Sanity package for building studios and apps",
  "keywords": [
    "cli",
    "cms",
    "content",
    "headless",
    "realtime",
    "sanity",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/cli.git",
    "directory": "packages/@sanity/cli-build"
  },
  "files": [
    "./dist",
    "!./dist/**/__tests__",
    "./static"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./_internal/build": {
      "source": "./src/_exports/_internal/build.ts",
      "default": "./dist/_exports/_internal/build.js"
    },
    "./_internal/env": {
      "source": "./src/_exports/_internal/env.ts",
      "default": "./dist/_exports/_internal/env.js"
    },
    "./_internal/extract": {
      "source": "./src/_exports/_internal/extract.ts",
      "default": "./dist/_exports/_internal/extract.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oclif/core": "^4.11.14",
    "@rolldown/plugin-babel": "^0.2.3",
    "@sanity/generate-help-url": "^4.0.0",
    "@sanity/schema": "^6.5.0",
    "@sanity/telemetry": "^1.1.0",
    "@sanity/types": "^6.5.0",
    "@vitejs/plugin-react": "^6.0.3",
    "chokidar": "^5.0.0",
    "cjs-module-lexer": "^2.2.0",
    "debug": "^4.4.3",
    "empathic": "^2.0.1",
    "lodash-es": "^4.18.1",
    "node-html-parser": "^7.1.0",
    "oneline": "^2.0.0",
    "picomatch": "^4.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "semver": "^7.8.1",
    "vite": "^8.1.5",
    "zod": "^4.4.3",
    "@sanity/cli-core": "^2.5.1",
    "@sanity/workbench-cli": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@sanity/pkg-utils": "^11.0.9",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/debug": "^4.1.13",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.20.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-istanbul": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.7.0",
    "magic-string": "^0.30.21",
    "publint": "^0.3.21",
    "sanity": "^6.5.0",
    "styled-components": "^6.4.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "@repo/package.config": "0.0.1",
    "@repo/tsconfig": "3.70.0",
    "@sanity/cli-test": "6.0.1",
    "@sanity/eslint-config-cli": "^1.1.3"
  },
  "peerDependencies": {
    "babel-plugin-react-compiler": "*"
  },
  "peerDependenciesMeta": {
    "babel-plugin-react-compiler": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "build": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src",
    "build:types": "pkg-utils build --emitDeclarationOnly",
    "check:types": "tsc --noEmit",
    "lint": "eslint .",
    "publint": "publint",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  }
}